.food-card {
  display: flex;
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx;
  align-items: stretch;
  border: 1rpx solid var(--ft-color-border);
  border-radius: var(--ft-radius-card);
  background: var(--ft-color-surface);
  box-shadow: var(--ft-shadow-card);
  color: var(--ft-color-text);
  text-align: left;
  line-height: 1.4;
  transition: transform 120ms ease;
}

.food-card-pressed {
  transform: scale(0.98);
}

.food-photo {
  width: 140rpx;
  height: 140rpx;
  flex: 0 0 140rpx;
  border-radius: 22rpx;
  background: var(--ft-color-primary-soft);
}

.food-photo-placeholder {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff5ec;
}

.placeholder-plate {
  width: 72rpx;
  height: 72rpx;
  border: 4rpx solid #efb49d;
  border-radius: 50%;
  box-shadow: inset 0 0 0 14rpx #fffaf5;
}

.placeholder-spark {
  position: absolute;
  top: 14rpx;
  right: 14rpx;
  color: var(--ft-color-orange);
  font-size: 24rpx;
}

.food-content {
  min-width: 0;
  flex: 1;
  padding: 6rpx 4rpx 4rpx 22rpx;
}

.food-header {
  display: flex;
  align-items: flex-start;
}

.food-name {
  min-width: 0;
  flex: 1;
  overflow: hidden;
  font-size: 28rpx;
  font-weight: 600;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rating-sticker {
  margin-left: 12rpx;
  padding: 8rpx 12rpx;
  border-radius: 14rpx;
  background: #fff0d8;
  color: #d87933;
  font-size: 20rpx;
  font-weight: 700;
}

.food-meta {
  overflow: hidden;
  margin-top: 10rpx;
  color: var(--ft-color-text-secondary);
  font-size: 21rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tag-row {
  display: flex;
  overflow: hidden;
  margin-top: 16rpx;
}

.tag-chip,
.status-chip {
  flex: 0 0 auto;
  margin-right: 8rpx;
  padding: 7rpx 12rpx;
  border-radius: 14rpx;
  background: var(--ft-color-primary-soft);
  color: var(--ft-color-primary);
  font-size: 19rpx;
  font-weight: 500;
  line-height: 1.2;
}

.status-chip {
  display: inline-block;
  margin-top: 14rpx;
}

.status-chip-VISITED {
  background: var(--ft-color-sage-soft);
  color: #64845b;
}

.status-chip-BLACKLISTED {
  background: var(--ft-color-danger-soft);
  color: #93665d;
}
