.quick-card {
  position: relative;
  display: block;
  width: 100%;
  height: 220rpx;
  padding: 26rpx;
  border: 1rpx solid var(--ft-color-border);
  border-radius: var(--ft-radius-card);
  background: var(--ft-color-surface);
  box-shadow: var(--ft-shadow-card);
  color: var(--ft-color-text);
  text-align: left;
  transition: transform 120ms ease, background-color 120ms ease;
}

.quick-card-orange {
  background: #fffaf5;
}

.quick-card-sage {
  background: #f8fbf6;
}

.quick-card-pressed {
  transform: scale(0.97);
}

.quick-icon {
  position: relative;
  display: flex;
  width: 58rpx;
  height: 58rpx;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  background: var(--ft-color-primary-soft);
  color: var(--ft-color-primary);
}

.quick-card-sage .quick-icon {
  background: var(--ft-color-sage-soft);
  color: #64845b;
}

.quick-icon-search::before {
  width: 22rpx;
  height: 22rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
  content: '';
}

.quick-icon-search::after {
  position: absolute;
  right: 11rpx;
  bottom: 11rpx;
  width: 16rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: currentColor;
  content: '';
  transform: rotate(45deg);
}

.quick-add {
  font-size: 40rpx;
  font-weight: 400;
  line-height: 1;
}

.quick-title {
  margin-top: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.35;
}

.quick-description {
  display: -webkit-box;
  overflow: hidden;
  margin-top: 6rpx;
  padding-right: 20rpx;
  color: var(--ft-color-text-secondary);
  font-size: 22rpx;
  font-weight: 400;
  line-height: 1.45;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.quick-arrow {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  width: 15rpx;
  height: 15rpx;
  border-top: 3rpx solid #b9a49b;
  border-right: 3rpx solid #b9a49b;
  transform: rotate(45deg);
}
