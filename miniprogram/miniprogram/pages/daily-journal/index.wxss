page {
  background: var(--ft-color-background);
}

.journal-page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 34rpx 28rpx calc(48rpx + env(safe-area-inset-bottom));
}

.journal-state {
  align-items: center;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 70vh;
  padding: 32rpx;
  text-align: center;
}

.journal-state--loading {
  animation: ft-rise-in 360ms ease-out both;
}

.journal-state__title {
  color: var(--ft-color-text);
  font-size: 34rpx;
  font-weight: 650;
  letter-spacing: 1rpx;
  line-height: 1.45;
  margin-top: 34rpx;
}

.journal-state__hint {
  color: var(--ft-color-text-secondary);
  font-size: 27rpx;
  line-height: 1.6;
  margin: 14rpx 0 34rpx;
}

.journal-state__symbol {
  align-items: center;
  background: var(--ft-color-primary-soft);
  border-radius: 50%;
  color: var(--ft-color-primary);
  display: flex;
  font-size: 52rpx;
  height: 112rpx;
  justify-content: center;
  width: 112rpx;
}

.notebook-loader {
  background: var(--ft-color-surface);
  border: 2rpx solid var(--ft-color-border);
  border-radius: 28rpx;
  box-shadow: var(--ft-shadow-card);
  box-sizing: border-box;
  height: 210rpx;
  padding: 66rpx 30rpx 20rpx;
  position: relative;
  transform: rotate(-2deg);
  width: 260rpx;
}

.notebook-loader__tape {
  background: rgba(255, 154, 98, 0.45);
  height: 38rpx;
  left: 78rpx;
  position: absolute;
  top: -18rpx;
  transform: rotate(4deg);
  width: 108rpx;
}

.notebook-loader__line {
  background: var(--ft-color-border);
  border-radius: 99rpx;
  height: 12rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  width: 100%;
}

.notebook-loader__line::after {
  animation: notebook-loading 1.25s ease-in-out infinite;
  background: var(--ft-color-primary);
  border-radius: inherit;
  content: '';
  display: block;
  height: 100%;
  width: 45%;
}

.notebook-loader__line--short {
  width: 68%;
}

.notebook-loader__dot {
  color: var(--ft-color-orange);
  font-size: 34rpx;
  position: absolute;
  right: 18rpx;
  top: 16rpx;
}

.preview-heading {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin: 6rpx 4rpx 30rpx;
}

.preview-heading__eyebrow {
  color: var(--ft-color-primary);
  display: block;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  margin-bottom: 8rpx;
}

.preview-heading__title {
  color: var(--ft-color-text);
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  line-height: 1.35;
}

.preview-heading__stamp {
  background: var(--ft-color-primary-soft);
  border: 2rpx dashed var(--ft-color-primary);
  border-radius: 50%;
  color: var(--ft-color-primary);
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 650;
  padding: 22rpx 14rpx;
  transform: rotate(6deg);
}

.poster-frame {
  animation: ft-rise-in 380ms ease-out both;
  background: var(--ft-color-surface);
  border: 2rpx solid var(--ft-color-border);
  border-radius: var(--ft-radius-large);
  box-shadow: var(--ft-shadow-floating);
  padding: 18rpx;
  position: relative;
}

.poster-frame__tape {
  background: rgba(255, 154, 98, 0.5);
  height: 34rpx;
  left: 50%;
  position: absolute;
  top: -18rpx;
  transform: translateX(-50%) rotate(-2deg);
  width: 120rpx;
  z-index: 1;
}

.poster-frame__image {
  border-radius: calc(var(--ft-radius-large) - 10rpx);
  display: block;
  overflow: hidden;
  width: 100%;
}

.journal-actions {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 34rpx;
}

.journal-actions__minor {
  display: flex;
  justify-content: center;
  gap: 18rpx;
}

.text-action {
  background: transparent;
  border-radius: 18rpx;
  color: var(--ft-color-primary);
  font-size: 27rpx;
  line-height: 80rpx;
  margin: 0;
  min-height: 80rpx;
  padding: 0 24rpx;
}

.text-action::after {
  border: 0;
}

.text-action:active {
  background: var(--ft-color-primary-soft);
}

.share-hint {
  color: var(--ft-color-text-secondary);
  display: block;
  font-size: 23rpx;
  line-height: 1.55;
  margin-top: 18rpx;
  text-align: center;
}

@keyframes notebook-loading {
  0%,
  100% {
    transform: translateX(-20%);
  }
  50% {
    transform: translateX(140%);
  }
}
