.profile-page { min-height: 100vh; padding: 30rpx 28rpx 64rpx; }
.state-card, .profile-card, .menu-card, .privacy-card { background: #fff; border: 1rpx solid var(--ft-color-border); border-radius: var(--ft-radius-card); box-shadow: var(--ft-shadow-card); padding: 30rpx; }
.state-card { align-items: center; display: flex; flex-direction: column; min-height: 240rpx; justify-content: center; }.secondary { background: var(--ft-color-primary-soft); color: var(--ft-color-primary); margin-top: 20rpx; }
.profile-card { align-items: center; display: flex; flex-direction: column; }.avatar { align-items: center; background: var(--ft-color-primary-soft); border-radius: 34rpx; color: var(--ft-color-primary); display: flex; font-size: 40rpx; font-weight: 700; height: 116rpx; justify-content: center; width: 116rpx; }.name { font-size: 34rpx; font-weight: 700; margin-top: 18rpx; }.subtitle { color: var(--ft-color-text-secondary); font-size: 23rpx; margin-top: 5rpx; }
.menu-card { align-items: center; display: flex; justify-content: space-between; margin-top: 22rpx; text-align: left; width: 100%; }.menu-title, .privacy-title { display: block; font-size: 29rpx; font-weight: 650; }.menu-copy, .privacy-copy { color: var(--ft-color-text-secondary); display: block; font-size: 23rpx; line-height: 1.6; margin-top: 7rpx; }.arrow { color: var(--ft-color-primary); font-size: 50rpx; }
.privacy-card { margin-top: 22rpx; }.logout { background: #f6e9e6; border-radius: 20rpx; color: #9e4d42; margin-top: 30rpx; min-height: 80rpx; width: 100%; }
