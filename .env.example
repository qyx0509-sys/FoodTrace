# Runtime
NODE_ENV=development
PORT=3000
API_HOST=0.0.0.0
API_PREFIX=api/v1
API_BASE_URL=http://127.0.0.1:3000
SWAGGER_ENABLED=true
CORS_ORIGINS=
LOG_LEVEL=debug

# PostgreSQL (replace placeholders in a local, ignored .env file)
POSTGRES_DB=foodtrace
POSTGRES_USER=foodtrace
POSTGRES_PASSWORD=
POSTGRES_PORT=5432
DATABASE_URL=postgresql://foodtrace:REPLACE_ME@127.0.0.1:5432/foodtrace

# JWT (server only)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ISSUER=foodtrace-api
JWT_AUDIENCE=foodtrace-client
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# WeChat (server secrets must never be copied to a client)
WECHAT_MINI_APP_ID=
WECHAT_MINI_APP_SECRET=
WECHAT_MOBILE_APP_ID=
WECHAT_MOBILE_APP_SECRET=

# Tencent Location Service (server WebService key)
TENCENT_MAP_WEB_SERVICE_KEY=

# Tencent COS (prefer an instance role in production)
TENCENT_CLOUD_SECRET_ID=
TENCENT_CLOUD_SECRET_KEY=
TENCENT_COS_BUCKET=
TENCENT_COS_REGION=ap-shanghai
TENCENT_COS_UPLOAD_TTL_SECONDS=900
TENCENT_COS_READ_URL_TTL_SECONDS=300

# Public client build configuration (not permanent secrets)
MINIPROGRAM_API_BASE_URL=http://127.0.0.1:3000/api/v1
FLUTTER_API_BASE_URL=http://127.0.0.1:3000/api/v1
TENCENT_MAP_MINIPROGRAM_KEY=
TENCENT_MAP_ANDROID_KEY=
TENCENT_MAP_IOS_KEY=
